{
	"name": "AAA-Golf",
	"tree": {
		"$className": "DataModel",

		"ReplicatedStorage": {
			"$path": "src/ReplicatedStorage",
			"Network": {
				"$className": "Folder",
				"RemoteEvents": {
					"$className": "Folder",
					"AdminBroadcast":     { "$className": "RemoteEvent" },
					"BallPositionStream": { "$className": "UnreliableRemoteEvent" },
					"GameBus":            { "$className": "RemoteEvent" },
					"HoleComplete":       { "$className": "RemoteEvent" },
					"MatchComplete":      { "$className": "RemoteEvent" },
					"ScoreboardUpdate":   { "$className": "RemoteEvent" },
					"WeatherChanged":     { "$className": "RemoteEvent" }
				},
				"RemoteFunctions": {
					"$className": "Folder",
					"GetCourseData":    { "$className": "RemoteFunction" },
					"GetPlayerProfile": { "$className": "RemoteFunction" },
					"PingCheck":        { "$className": "RemoteFunction" },
					"ValidateShopItem": { "$className": "RemoteFunction" }
				}
			}
		},

		"ServerScriptService": {
			"$path": "src/ServerScriptService"
		},

		"StarterPlayer": {
			"$path": "src/StarterPlayer"
		},

		"StarterGui": {
			"$path": "src/StarterGui"
		},

		"Workspace": {
			"$className": "Workspace",
			"$properties": {
				"StreamingEnabled": true,
				"FilteringEnabled": true
			},
			"Courses": {
				"$path": "src/Workspace/Courses"
			},
			"SpawnPoints": {
				"$className": "Folder"
			},
			"Cameras": {
				"$className": "Folder"
			},
			"Map": {
				"$className": "Folder"
			},
			"CurrentWeather": {
				"$className": "StringValue",
				"$properties": {
					"Value": "Clear"
				}
			}
		}
	}
}
